# Supabase — públicas (já têm fallback no código)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-publishable-key

# ====== SECRETS (servidor) — NUNCA versionar com valor real ======
# Na Cloudflare: Workers & Pages > seraviecampo > Settings > Variables and secrets
# Adicione como "Secret". No Stripe (modo teste) você obtém:

# Chave secreta da API (sk_test_... em teste)
STRIPE_SECRET_KEY=
# Segredo do endpoint de webhook (whsec_...) — endpoint: /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=
# IDs de preço (price_...) dos planos de assinatura, criados no painel do Stripe
STRIPE_PRICE_GOURMET=
STRIPE_PRICE_PREMIUM=

# Apenas se for usar service role no servidor (NUNCA no client)
SUPABASE_SERVICE_ROLE_KEY=
